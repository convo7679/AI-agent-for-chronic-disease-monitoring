# ============================================================
# ChronicCare AI — Environment Configuration Template
# ============================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your credentials below
#   3. NEVER commit your .env file to version control
#   4. Add .env to your .gitignore (already done)
# ============================================================

# ------------------------------------------------------------
# IBM watsonx.ai Credentials (REQUIRED)
# Get from: https://cloud.ibm.com → Manage → API Keys
# ------------------------------------------------------------
IBM_API_KEY=your_ibm_cloud_api_key_here
IBM_PROJECT_ID=your_watsonx_project_id_here

# IBM Region — choose the region closest to you
IBM_REGION=us-south

# IBM watsonx.ai Inference Endpoint
# us-south : https://us-south.ml.cloud.ibm.com
# eu-gb    : https://eu-gb.ml.cloud.ibm.com
# eu-de    : https://eu-de.ml.cloud.ibm.com
# jp-tok   : https://jp-tok.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ------------------------------------------------------------
# IBM Granite Model Selection
# ------------------------------------------------------------
# Recommended:
#   ibm/granite-3-8b-instruct   (fast, accurate — default)
#   ibm/granite-13b-chat-v2     (more detailed responses)
#   ibm/granite-20b-multilingual (multilingual support)
GRANITE_MODEL_ID=ibm/granite-3-8b-instruct

# ------------------------------------------------------------
# Flask Application Settings
# ------------------------------------------------------------
# IMPORTANT: Generate a strong secret key for production:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production

# Environment: development | production
FLASK_ENV=development
FLASK_DEBUG=False

# Server port (Render auto-sets PORT — do not override in production)
PORT=5000

# ------------------------------------------------------------
# AI Model Parameters
# ------------------------------------------------------------
MAX_TOKENS=1024
TEMPERATURE=0.7
TOP_P=0.9
TOP_K=50

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# SQLite (development — auto-created):
DATABASE_URL=sqlite:///data/chroniccare.db

# PostgreSQL (production example):
# DATABASE_URL=postgresql://user:password@host:5432/chroniccare

# ------------------------------------------------------------
# Security Settings
# ------------------------------------------------------------
# Set to True in production (HTTPS required)
WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=False
